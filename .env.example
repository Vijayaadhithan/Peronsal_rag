# Ollama runs locally by default. Change this only for a different host/port.
OLLAMA_BASE_URL=http://localhost:11434

# MySQL source for ads ingestion.
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=rag_ht_test
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_TABLE=ads_search_ready
MYSQL_CONTENT_COLUMN=embedding_content
MYSQL_BM25_COLUMN=bm25_content
MYSQL_SEARCH_ID_COLUMN=id

# Canonical product rows returned after semantic retrieval and reranking.
MYSQL_RESULT_TABLE=ads
MYSQL_RESULT_ID_COLUMN=id
